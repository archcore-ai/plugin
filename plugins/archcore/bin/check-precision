#!/bin/sh
# PostToolUse hook: emit precision-check warnings for newly created or updated
# .archcore/ documents. Soft mode — always exits 0, never blocks.
#
# Phase 1 of the Precision Initiative (see precision-over-coverage.adr.md).
# Findings are surfaced via archcore_hook_info as additionalContext so the
# authoring LLM can choose to revise. Pre-existing documents are unaffected;
# warnings reflect the state of the document just written.
#
# Checks:
#   1. Forbidden vagueness lexicon (precision-rules.rule.md)
#   2. Mandatory sections by document type
#   3. Frontmatter title and status presence
#   4. Body length above placeholder threshold
#   5. No cross-document body references to other .archcore/ documents
#      (precision-rules.rule.md Rule 5 — relations belong in the graph)
#   6. No multi-line code blocks (>=5 content lines) in architect-voice types
#      (precision-rules.rule.md Rule 6 — use @references instead)
#   7. Spec notation (spec-contract.md): BCP 14 modals (no SHALL), the 80-line
#      body cap, and — on numbered lines only — strict-EARS grammar: one modal
#      per line (7b, no compound requirements) and an obligated active-voice
#      subject (7c, no subjectless passive). Advisory only — legacy specs warn
#      on next edit, never retroactively (migrate-on-next-edit policy).

SCRIPT_DIR=$(dirname "$0")
# shellcheck source=lib/normalize-stdin.sh
. "$SCRIPT_DIR/lib/normalize-stdin.sh"

# --- Filter: only run on document-mutation MCP tools ---
case "$ARCHCORE_TOOL_NAME" in
  mcp__archcore__create_document|mcp__archcore__update_document)
    ;;
  *)
    exit 0
    ;;
esac

# --- Resolve document path on disk ---
if [ -z "$ARCHCORE_DOC_PATH" ]; then
  exit 0
fi

DOC_FILE="$ARCHCORE_DOC_PATH"
case "$ARCHCORE_DOC_PATH" in
  .archcore/*) ;;
  *) DOC_FILE=".archcore/$ARCHCORE_DOC_PATH" ;;
esac

[ -f "$DOC_FILE" ] || exit 0

# --- Detect document type from filename pattern slug.<type>.md ---
DOC_TYPE=$(basename "$DOC_FILE" | sed -n 's/.*\.\([a-z][a-z-]*\)\.md$/\1/p')

# --- Split frontmatter and body (POSIX awk) ---
HEAD=$(awk 'BEGIN{c=0} /^---$/{c++; if (c==2) exit} c>=1' "$DOC_FILE")
BODY=$(awk 'BEGIN{c=0} /^---$/{c++; next} c>=2' "$DOC_FILE")

# --- Findings accumulator ---
FINDINGS=""
add_finding() {
  if [ -z "$FINDINGS" ]; then
    FINDINGS="$1"
  else
    FINDINGS="$FINDINGS; $1"
  fi
}

# --- Check 1: Forbidden vagueness lexicon ---
# Source of truth: skills/_shared/precision-rules.md (Rule 1).
# Hardcoded here for hook performance; keep in sync manually for now.
FORBIDDEN_EN='\b(appropriate|robust|scalable|modern|various|optimal|efficient|flexible|convenient|seamless|streamlined)\b'
FORBIDDEN_RU='(оптимальный|удобный|правильный|надёжный|гибкий|современный|передовой|эффективный|масштабируемый)'
FORBIDDEN_PHRASES='best practices|as needed|world.class|cutting.edge'

HITS=$(printf '%s' "$BODY" | grep -ioE "$FORBIDDEN_EN|$FORBIDDEN_RU|$FORBIDDEN_PHRASES" 2>/dev/null \
  | tr '[:upper:]' '[:lower:]' | sort -u | head -5 | tr '\n' ',' | sed 's/,$//')
if [ -n "$HITS" ]; then
  add_finding "forbidden words ($HITS) — replace with concrete fact, version, or measurement"
fi

# --- Check 2: Mandatory sections per type ---
check_section() {
  _section="$1"
  if ! printf '%s' "$BODY" | grep -qE "^##[[:space:]]+${_section}([[:space:]]|$)"; then
    add_finding "missing section: ## $_section"
  fi
}

case "$DOC_TYPE" in
  adr)
    check_section "Context"
    check_section "Decision"
    check_section "Alternatives Considered"
    check_section "Consequences"
    ;;
  rule)
    check_section "Rule"
    check_section "Rationale"
    check_section "Enforcement"
    ;;
  spec)
    check_section "Purpose"
    # Canonical heading is "Surface"; "Contract Surface" is the pre-canon legacy
    # heading — accepted so existing corpora don't produce advisory noise.
    check_section "(Contract )?Surface"
    check_section "Normative Behavior"
    check_section "Conformance"
    ;;
  guide)
    check_section "Steps"
    check_section "Verification"
    ;;
  rfc)
    check_section "Summary"
    check_section "Motivation"
    check_section "Detailed Design"
    ;;
  *)
    # plan, prd, idea, doc, mrd/brd/urd/etc., cpat, task-type — no structural
    # checks at this phase; precision-rules still apply.
    ;;
esac

# --- Check 3: Frontmatter completeness ---
if ! printf '%s' "$HEAD" | grep -qE '^title:[[:space:]]*[^[:space:]]'; then
  add_finding "frontmatter: missing or empty title"
fi
if ! printf '%s' "$HEAD" | grep -qE '^status:[[:space:]]*(draft|accepted|rejected)'; then
  add_finding "frontmatter: missing or invalid status"
fi

# --- Check 4: Body length (placeholder detection) ---
BODY_LEN=$(printf '%s' "$BODY" | wc -c | tr -d ' ')
if [ "$BODY_LEN" -lt 200 ]; then
  add_finding "body is $BODY_LEN chars (<200, likely placeholder)"
fi

# --- Check 5: Cross-document body references ---
# Source of truth: skills/_shared/precision-rules.md Rule 5.
# Cross-document links belong in the relation graph (mcp__archcore__add_relation),
# not enumerated as a markdown section in the body. Detect any .archcore/...md
# path reference; the hook is soft, so false positives are acceptable.
CROSS_HITS=$(printf '%s' "$BODY" | grep -oE '\.archcore/[A-Za-z0-9_./-]+\.md' 2>/dev/null \
  | sort -u | head -3 | tr '\n' ',' | sed 's/,$//')
if [ -n "$CROSS_HITS" ]; then
  add_finding "body references other .archcore/ documents ($CROSS_HITS) — move these links to the relation graph via mcp__archcore__add_relation"
fi

# --- Check 6: Multi-line code blocks in architect-voice types ---
# Source of truth: skills/_shared/precision-rules.md Rule 6.
# Code blocks with >=5 content lines signal pasted implementation detail;
# types where architect voice applies must prefer @path/to/file references.
# Exempted types (code blocks are the artifact): rule, guide, cpat.
case "$DOC_TYPE" in
  adr|rfc|doc|prd|idea|plan|mrd|brd|urd|brs|strs|syrs|srs)
    LONG_BLOCK=$(printf '%s' "$BODY" | awk '
      /^[[:space:]]*```/ {
        if (in_block) {
          # closing fence: check accumulated line count
          if (block_lines >= 5) { found = 1; exit }
          in_block = 0
          block_lines = 0
        } else {
          in_block = 1
          block_lines = 0
        }
        next
      }
      in_block { block_lines++ }
      END { if (found) print "yes" }
    ')
    if [ "$LONG_BLOCK" = "yes" ]; then
      add_finding "code block >=5 lines in $DOC_TYPE — architect voice prefers @path/to/file references over pasted implementation detail (Rule 6)"
    fi
    ;;
esac

# --- Check 7: Spec notation ---
# Source of truth: skills/_shared/spec-contract.md. SHALL is the pure-EARS
# keyword, not part of the EARS + BCP 14 hybrid; the body cap is 80 lines
# (120 applies only to init-synthesized flagship specs).
if [ "$DOC_TYPE" = "spec" ]; then
  if printf '%s' "$BODY" | grep -qE '\bSHALL\b'; then
    add_finding "spec notation: SHALL found — grade with BCP 14 modals instead (MUST / SHOULD / MAY, uppercase)"
  fi
  BODY_LINES=$(printf '%s\n' "$BODY" | wc -l | tr -d ' ')
  if [ "$BODY_LINES" -gt 80 ]; then
    add_finding "spec body is $BODY_LINES lines (cap 80; 120 only for init-synthesized flagship specs)"
  fi

  # Checks 7b/7c apply only to numbered lines (^[0-9]+.) — Normative + Failure
  # Behavior. Constraints & Invariants (plain BCP 14, non-EARS by design) and
  # prose are never touched.

  # Check 7b: compound requirement — >=2 BCP 14 modals in one numbered line.
  # Normalize the NOT-forms first so "MUST NOT" counts as one modal, then count.
  COMPOUND=$(printf '%s\n' "$BODY" | grep -E '^[0-9]+\.' | while IFS= read -r _l; do
    _n=$(printf '%s' "$_l" | sed -E 's/(MUST|SHOULD|SHALL|MAY) NOT/\1/g' \
      | grep -oE '\b(MUST|SHOULD|SHALL|MAY)\b' | wc -l | tr -d ' ')
    [ "${_n:-0}" -ge 2 ] && printf 'x'
  done)
  if [ -n "$COMPOUND" ]; then
    add_finding "compound requirement — a numbered line carries >=2 modal keywords; one requirement (one modal) per line, split \"MUST X and MUST NOT Y\" into two lines"
  fi

  # Check 7c: subjectless passive — "MUST/SHOULD be <verb-ed/-en>" (EN) or
  # "MUST/SHOULD <verb>ться/тся" (RU) on a numbered line names no obligated actor.
  # Case-sensitive on the modal (RFC 8174: only uppercase is normative), matching
  # the SHALL check above. Implicit-trigger deviation (event as grammatical
  # subject without WHEN) is not reliably lintable — it stays a contract/prose
  # rule in spec-contract.md, not a hook check.
  PASSIVE=$(printf '%s\n' "$BODY" | grep -E '^[0-9]+\.' \
    | grep -oE '\b(MUST|SHOULD)( NOT)? be [a-z]+(ed|en)\b|\b(MUST|SHOULD)( NOT)? [^[:space:]]+(ться|тся)\b' 2>/dev/null \
    | head -3 | tr '\n' ',' | sed 's/,$//')
  if [ -n "$PASSIVE" ]; then
    add_finding "subjectless passive ($PASSIVE) — name the obligated component as the subject, e.g. \"the <component> MUST rotate <thing>\", or use WHEN <trigger> if it responds to an event"
  fi
fi

# --- Emit soft warnings if any ---
if [ -n "$FINDINGS" ]; then
  archcore_hook_info "Precision check on $ARCHCORE_DOC_PATH (soft, non-blocking) — $FINDINGS. See skills/_shared/precision-rules.md and adr-contract.md (plugin-shipped)."
fi

exit 0
